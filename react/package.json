{
  "name": "y-sync-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run pre-build && concurrently \"vite\" \"npm run backend\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
